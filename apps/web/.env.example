# Caspilot web — public client config. Copy to .env.local. NEXT_PUBLIC_* values are
# inlined into the browser bundle, so put ONLY public identifiers here — never a
# CSPR.cloud key or any private key.

# Base URL of the Caspilot API (intents trace + build-unsigned-deploy + confirm-onchain).
NEXT_PUBLIC_CASPILOT_API_BASE=http://localhost:8787

# Public CSPR.click application id (register at https://console.cspr.click). Required
# for the live wallet popup: without it the wallet stays in offline mode and the
# "Sign & submit on testnet" action reports that signing is not configured. This is a
# PUBLIC app id, not a secret — the CSPR.click proxy holds the privileged CSPR.cloud
# credentials, the frontend never sees them.
NEXT_PUBLIC_CSPRCLICK_APP_ID=
